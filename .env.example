# Sao chép thành .env và chỉnh giá trị.

# --- Gemini (tuỳ chọn) ---
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

PORT=3001

# --- Postgres ---
# Local (khớp docker-compose.yml trong thư mục này):
#   docker compose up -d
DATABASE_URL=postgres://qc:qc@localhost:5432/qc

# Remote (Render / Neon / …): dán URL từ dashboard (đủ hostname + thường có ?sslmode=require).
# Render: thêm :5432 và ?sslmode=require (thiếu SSL dễ ECONNRESET).
# Node pg ≥8 có thể in cảnh báo sslmode: thêm &uselibpqcompat=true để giữ semantics libpq (theo gợi ý của driver).
# Ví dụ: .../dbname?sslmode=require&uselibpqcompat=true


# --- R2 ảnh chụp bước (tuỳ chọn — thiếu thì giữ base64 trong DB như trước) ---
# R2 dashboard → Account Details → S3 API / endpoint; Manage API Tokens → Access Key ID + Secret.
# R2_SIGNED_URL_TTL_SECONDS: thời gian sống link GET khi mở chi tiết lần chạy (mặc định 3600).

R2_ENDPOINT=
R2_BUCKET=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_REGION=auto
R2_SIGNED_URL_TTL_SECONDS=3600

